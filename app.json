{
  "expo": {
    "name": "鲨壁",
    "slug": "shabi-android",
    "version": "1.0.5",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.colorfulshark.shabi"
    },
    "android": {
      "package": "com.colorfulshark.shabi",
      "versionCode": 6,
      "adaptiveIcon": {
        "backgroundColor": "#4B2E94",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": []
    },
    "plugins": [
      "expo-video",
      "expo-secure-store",
      [
        "expo-status-bar",
        {
          "style": "light",
          "hidden": false
        }
      ]
    ],
    "web": {
      "favicon": "./assets/favicon.png"
    }
  }
}
